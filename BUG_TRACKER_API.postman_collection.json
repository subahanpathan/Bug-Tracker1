    {
      "name": "Tickets/Bugs",
      "item": [
        {
          "name": "Get All Tickets",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/bugs?projectId={{projectId}}&status=open&priority=high",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "bugs"],
              "query": [
                {
                  "key": "projectId",
                  "value": "{{projectId}}"
                },
                {
                  "key": "status",
                  "value": "open",
                  "disabled": true
                },
                {
                  "key": "priority",
                  "value": "high",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "Create Ticket",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Fix login button\",\n  \"description\": \"The login button is not responding on mobile devices\",\n  \"projectId\": \"{{projectId}}\",\n  \"priority\": \"high\",\n  \"assigneeId\": \"user-id-here\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/bugs",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "bugs"]
            }
          }
        },
